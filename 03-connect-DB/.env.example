# Server Configuration
PORT=8000
NODE_ENV=development

# Database Configuration
MONGODB_URL=mongodb://localhost:27017
DB_NAME=AshishChoudhary

# CORS Configuration
CORS_ORIGIN=*

# JWT Configuration
# Generate secret using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCESS_TOKEN_SECRET=your-access-token-secret-key-here
ACCESS_TOKEN_EXPIRY=1d

REFRESH_TOKEN_SECRET=your-refresh-token-secret-key-here
REFRESH_TOKEN_EXPIRY=10d

# File Upload (Cloudinary) - Optional
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
